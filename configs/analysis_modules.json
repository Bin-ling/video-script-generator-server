      "config": {
        "input_prompt_template": "播放：{play}  点赞：{like}  评论：{comment}  收藏：{collect}  分享：{share}  时长：{duration}s\n\n分析：\n{output_keywords}",
        "output_keywords": ["数据评级", "互动率", "完播预估", "受众匹配", "优化方向"]
